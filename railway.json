{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd server && npm install --omit=dev"
  },
  "deploy": {
    "startCommand": "cd server && node server.js",
    "healthcheckPath": "/api/public/settings",
    "restartPolicyType": "ON_FAILURE"
  }
}
